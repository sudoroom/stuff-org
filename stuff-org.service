[Unit]
Description=stuff-org.service
After=network.target

[Service]
User=stuff
Restart=always
RestartSec=10
ExecStart=/home/stuff/stuff-org/run.sh

StandardOutput=append:/var/log/stuff-org.log
StandardError=append:/var/log/stuff-org_error.log
# using file: instead of append: would create a new file eeach time

[Install]
WantedBy=multi-user.target
